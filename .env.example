# ==========================================================
# StelarStrike — environment configuration
#
# HOW TO USE:
#   cp .env.example .env
#   Edit .env with your values
#   Never commit your real .env file (it is in .gitignore)
# ==========================================================

# ---- AI (OpenCode) ----
# Install OpenCode first: curl -fsSL https://opencode.ai/install | bash
# Then run: opencode models  (to see all available models)
STELAR_AI_ENABLED=true
OPENCODE_MODEL=opencode/big-pickle

# ---- Logging ----
STELAR_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# ---- HTTP settings ----
STELAR_TIMEOUT_SECONDS=15
STELAR_MAX_CONCURRENCY=10
STELAR_USER_AGENT=StelarStrike/0.2 (+https://github.com/ronaega/stelarstrike)

# ---- Reports ----
STELAR_REPORT_DIR=reports
