# ==========================================================
# StelarStrike — environment configuration
# Copy this file to ".env" and fill in the values you need.
# Never commit your real ".env" file.
# ==========================================================

# ---- Core ----
STELAR_ENV=development                 # development | ci | production
STELAR_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
STELAR_CONFIG_PATH=config/config.yaml  # path to the main YAML config
STELAR_REPORT_DIR=reports              # where generated reports are written
STELAR_TIMEOUT_SECONDS=15              # per-request HTTP timeout
STELAR_MAX_CONCURRENCY=10              # concurrent requests across all plugins
STELAR_USER_AGENT=StelarStrike/0.1 (+https://github.com/ronaega/stelarstrike)

# ---- Scope / safety ----
STELAR_REQUIRE_SCOPE_FILE=true         # refuse to scan targets not listed in scope.yaml
STELAR_ALLOW_ACTIVE_PAYLOADS=false     # true = send exploit-confirming payloads, false = passive/detection-only

# ---- AI (OpenCode — https://opencode.ai) ----
# StelarStrike uses OpenCode for AI-powered triage, report writing, and SQLi analysis.
#
# INSTALL OPENCODE (one-time, run in your terminal):
#   curl -fsSL https://opencode.ai/install | bash
#
# Default model: opencode/big-pickle (Big Pickle — the model used during development).
# To list all available models after installing OpenCode: opencode models
# To use a different model, change OPENCODE_MODEL below.
STELAR_AI_ENABLED=true
OPENCODE_MODEL=opencode/big-pickle

# ---- Notifications (optional) ----
STELAR_SLACK_WEBHOOK_URL=
STELAR_DISCORD_WEBHOOK_URL=

# ---- CI/CD (used by .github/workflows/ci.yml, safe to leave blank locally) ----
STELAR_CI_TARGET_URL=
