# ==========================================================
# StelarStrike — environment configuration
# Copy this file to ".env" and fill in the values you need.
# Never commit your real ".env" file.
# ==========================================================

# ---- Core ----
STELAR_ENV=development                 # development | ci | production
STELAR_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
STELAR_CONFIG_PATH=config/config.yaml  # path to the main YAML config
STELAR_REPORT_DIR=reports              # where generated reports are written
STELAR_TIMEOUT_SECONDS=15              # per-request HTTP timeout
STELAR_MAX_CONCURRENCY=10              # concurrent requests across all plugins
STELAR_USER_AGENT=StelarStrike/0.1 (+https://github.com/<your-username>/stelarstrike)

# ---- Scope / safety ----
STELAR_REQUIRE_SCOPE_FILE=true         # refuse to scan targets not listed in scope.yaml
STELAR_ALLOW_ACTIVE_PAYLOADS=false     # true = send exploit-confirming payloads, false = passive/detection-only

# ---- AI provider (used for triage, report writing, payload ranking) ----
# StelarStrike uses LiteLLM under the hood, so STELAR_AI_PROVIDER can be any
# LiteLLM-supported provider string, e.g.:
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-6
#   ollama/llama3.1            (fully local, no API key needed)
#   azure/<deployment-name>
STELAR_AI_PROVIDER=anthropic/claude-sonnet-4-6
STELAR_AI_ENABLED=true
STELAR_AI_MAX_TOKENS=2000
STELAR_AI_TEMPERATURE=0.2

# Only fill in the key that matches the provider you selected above
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Local model endpoint (only used if STELAR_AI_PROVIDER starts with "ollama/")
OLLAMA_BASE_URL=http://localhost:11434

# ---- Notifications (optional) ----
STELAR_SLACK_WEBHOOK_URL=
STELAR_DISCORD_WEBHOOK_URL=

# ---- CI/CD (used by .github/workflows/ci.yml, safe to leave blank locally) ----
STELAR_CI_TARGET_URL=
